# Maps secret NAMES (referenced in config/deploy.yml) to their VALUES, pulled from
# the environment. This file holds no raw credentials, so it is safe to commit.
#
# Provide the actual values via your shell (export ...) for local `kamal` runs, or
# as GitHub Actions secrets for the CI deploy. DATABASE_URL embeds the Postgres
# password and points at the `db` accessory's container name on Kamal's network:
#   DATABASE_URL=postgres://masaryk:<POSTGRES_PASSWORD>@masaryk_ex-db:5432/masaryk_ex_prod

KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
SECRET_KEY_BASE=$SECRET_KEY_BASE
DATABASE_URL=$DATABASE_URL
POSTGRES_PASSWORD=$POSTGRES_PASSWORD
BOT_TOKEN=$BOT_TOKEN
DISCORD_CLIENT_SECRET=$DISCORD_CLIENT_SECRET
