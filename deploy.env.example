# Template for Kamal deploy secrets. Copy to deploy.env and fill in real values:
#   cp deploy.env.example deploy.env
# deploy.env is gitignored; this template is safe to commit (no secrets here).
#
# Deploy via:    bin/deploy.sh                 (sources deploy.env for you)
# Or manually:   set -a; source deploy.env; set +a && kamal deploy

# ghcr.io token: a GitHub PAT (classic) with read:packages + write:packages
KAMAL_REGISTRY_PASSWORD=

# Phoenix secret — generate ONCE and keep it stable:  mix phx.gen.secret
# (Changing it invalidates all sessions/cookies on the next deploy.)
SECRET_KEY_BASE=

# Postgres password for the `db` accessory (must match the one inside DATABASE_URL)
POSTGRES_PASSWORD=

# Leave blank to let bin/deploy.sh derive it from POSTGRES_PASSWORD, or set the
# full URL:  postgres://masaryk:<POSTGRES_PASSWORD>@masaryk_ex-db:5432/masaryk_ex_prod
DATABASE_URL=

# Discord bot token — leave blank to run headless (no Discord connection)
BOT_TOKEN=

# Discord OAuth client secret (dashboard login)
DISCORD_CLIENT_SECRET=
