# Discord (only needed to run the bot itself; the CLI works without these)
BOT_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_dev_guild_id

# Database: defaults already match docker-compose (localhost:5433, postgres/postgres,
# db masaryk_ex_dev), so you usually don't need to set anything here.
# Override the port if you remap it:
# PGPORT=5433
# Or point at any Postgres with a full URL (takes precedence over PG* vars):
# DATABASE_URL=postgres://user:pass@host:5432/masaryk_ex_dev
